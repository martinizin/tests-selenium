        },
        {
          "id": "6ac0d42a-5eba-4c53-b01b-ffe1f00a63ea",
          "comment": "Usuario inexistente — fix Firefox initKeyEvent",
          "command": "executeScript",
          "target": "(function(){var el=document.getElementById('user-name');var s=Object.getOwnPropertyDescriptor(window.HTMLInputElement.prototype,'value').set;s.call(el,'wrong_user');el.dispatchEvent(new Event('input',{bubbles:true}));el.dispatchEvent(new Event('change',{bubbles:true}));})()",
          "targets": [],
          "value": ""
        },
        {
          "id": "2d1e98ee-ce4a-41e1-a400-a6ee6eb5715c",
          "comment": "Password incorrecta — fix Firefox initKeyEvent",
          "command": "executeScript",
          "target": "(function(){var el=document.getElementById('password');var s=Object.getOwnPropertyDescriptor(window.HTMLInputElement.prototype,'value').set;s.call(el,'wrong_pass');el.dispatchEvent(new Event('input',{bubbles:true}));el.dispatchEvent(new Event('change',{bubbles:true}));})()",
          "targets": [],
          "value": ""
        },
        {
          "id": "28fb4095-c077-4ccf-b66e-148d2a60962e",
          "comment": "",
          "command": "click",
          "target": "id=login-button",
          "targets": [],
          "value": ""
        },
        {
          "id": "aa81f05b-fc15-4c8d-acd2-5f8b02619150",
          "comment": "Verificacion blanda del error",
          "command": "verifyElementPresent",
          "target": "css=[data-test=\"error\"]",
          "targets": [],
          "value": ""
        },
        {
          "id": "9446a18f-2449-4fe1-afa1-af57e577f6b4",
          "comment": "Verificacion del mensaje exacto",
