{
  "id": "2bb85c61-fc91-425a-a53c-7a4681a31fd6",
  "version": "2.0",
  "name": "Proyecto_VV_Apellido_Nombre",
  "url": "https://www.saucedemo.com",
  "tests": [
    {
      "id": "2028a763-1aaa-4fb0-9da7-46c61d0bf8a7",
      "name": "CP01_Login_Happy_Path",
      "commands": [
        {
          "id": "578537d0-586f-4abe-bf1c-4ba949d43344",
          "comment": "Navegar a la URL base",
          "command": "open",
          "target": "/",
          "targets": [],
          "value": ""
        },
        {
          "id": "52aebb88-1371-434e-a6af-ede6186c14f5",
          "comment": "Resolucion estandar",
          "command": "setWindowSize",
          "target": "1280x800",
          "targets": [],
          "value": ""
        },
        {
          "id": "85f7e08e-2291-4c8b-aff8-e3dc6cea86ea",
          "comment": "Ingresar usuario valido — fix Firefox initKeyEvent",
          "command": "executeScript",
          "target": "(function(){var el=document.getElementById('user-name');var s=Object.getOwnPropertyDescriptor(window.HTMLInputElement.prototype,'value').set;s.call(el,'standard_user');el.dispatchEvent(new Event('input',{bubbles:true}));el.dispatchEvent(new Event('change',{bubbles:true}));})()",
          "targets": [],
          "value": ""
        },
        {
          "id": "c612daa7-cc8a-464d-a0f4-7891c59802db",
          "comment": "Ingresar password valida — fix Firefox initKeyEvent",
          "command": "executeScript",
          "target": "(function(){var el=document.getElementById('password');var s=Object.getOwnPropertyDescriptor(window.HTMLInputElement.prototype,'value').set;s.call(el,'secret_sauce');el.dispatchEvent(new Event('input',{bubbles:true}));el.dispatchEvent(new Event('change',{bubbles:true}));})()",
          "targets": [],
          "value": ""
        },
        {
          "id": "cd741753-9153-42a0-b863-a18506b7fcb4",
          "comment": "Enviar formulario",
          "command": "click",
          "target": "id=login-button",
          "targets": [],
          "value": ""
        },
        {
          "id": "16277541-e61d-49fe-ae12-f35f5b676f40",
          "comment": "Verificar titulo del dashboard",
          "command": "assertElementPresent",
          "target": "css=.title",
          "targets": [],
          "value": ""
        },
        {
          "id": "9c08ad76-a062-4c0c-9b4e-e69eb4ab3f61",
          "comment": "Asercion dura del happy path",
          "command": "assertText",
          "target": "css=.title",
          "targets": [],
          "value": "Products"
        },
        {
          "id": "1e26b23f-a7ca-49c9-8348-d2c241c2e57f",
          "comment": "Confirmar URL del dashboard — assertLocation no existe en IDE 4.x, se usa executeScript",
          "command": "executeScript",
          "target": "if(window.location.href!=='https://www.saucedemo.com/inventory.html')throw new Error('URL incorrecta: '+window.location.href);",
          "targets": [],
          "value": ""
        }
      ]
    },
    {
      "id": "d310d08c-3541-4ded-8f41-24e09804f669",
